---
import Layout from '../layouts/Layout.astro';

const KAKAO_CHANNEL_CUSTOMER = 'https://pf.kakao.com/_xxxxx?utm_source=landing&utm_medium=cta&utm_campaign=customer';
const KAKAO_CHANNEL_AGENT = 'https://pf.kakao.com/_xxxxx?utm_source=landing&utm_medium=cta&utm_campaign=agent';

const problems = [
  {
    title: '보험 가입했더니, 영업 전화만',
    description: '번호 한 번 남겼을 뿐인데, 모르는 번호로 며칠째 전화가 와요.',
  },
  {
    title: '약관 봐도, 뭐가 좋은지 모르겠어요',
    description: '외계어 같은 보험 용어들, 한 줄 한 줄 읽어도 이해가 안 돼요.',
  },
  {
    title: '어떤 상황에 얼마 받는지 모르겠어요',
    description: '가입하면 나에게 진짜 도움 되는 건지, 얼마나 보장받을 수 있는지 헷갈려요.',
  },
];

const steps = [
  {
    label: 'Request',
    title: '요청서를 남기세요',
    description: '어떤 보험이 필요한지 1분 안에 입력하면 끝. 가입자가 직접 설계사를 찾을 필요 없습니다.',
  },
  {
    label: 'Receive',
    title: '설계사가 제안서를 보냅니다',
    description: '별도 연락 없이 가입설계 제안서만 도착해요. 여러 설계사의 안을 한 번에 받아봅니다.',
  },
  {
    label: 'Select',
    title: 'AI 비교 결과로 선택하세요',
    description: '보장 내역과 예상 수령액을 AI가 정리해 보여드립니다. 마음에 드는 제안을 선택하면 끝.',
  },
];

const solutions = [
  {
    title: '별도 연락 없이, 제안서만 도착',
    description:
      '요청서를 남기면 설계사들이 가입설계 제안서를 플랫폼으로 직접 보내드립니다. 실제 계약할 설계사와만 대화하세요.',
  },
  {
    title: '복잡한 약관, AI가 쉽게 정리',
    description:
      '어려운 보험 용어와 약관을 AI가 핵심만 추출해 평문으로 설명합니다. 한 줄 한 줄 해석하지 않아도 됩니다.',
  },
  {
    title: '어떤 상황에 얼마 받는지 한눈에',
    description:
      '여러 제안서의 보장 내역과 예상 수령액을 AI가 비교 분석합니다. 가장 유리한 제안이 무엇인지 명확하게.',
  },
];
---

<Layout>
  <!-- Top Bar -->
  <header class="border-b border-hairline">
    <div class="mx-auto flex h-16 max-w-section items-center justify-between px-6">
      <a href="/" class="flex items-center" aria-label="Claim 홈">
        <img
          src="/claim_w_bg.png"
          alt="Claim"
          width="84"
          height="28"
          class="h-7 w-auto mix-blend-multiply"
        />
      </a>
      <span class="text-[13px] text-muted">사전예약 모집 중</span>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="px-6 pt-20 pb-24 sm:pt-28 sm:pb-32">
      <div class="mx-auto max-w-5xl">
        <div class="flex justify-center">
          <span class="inline-flex items-center gap-2 rounded-pill border border-hairline bg-canvas-soft px-3 py-1 text-[11px] font-semibold uppercase tracking-caption text-ink">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
            AI 보험 비교 플랫폼
          </span>
        </div>

        <h1 class="mt-8 text-center font-normal leading-[1.18] tracking-display text-ink text-[34px] sm:text-[52px] lg:text-[60px]">
          설계사가 제안하고,<br />
          AI가 비교하고,<br />
          당신은 선택합니다.
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-center text-base leading-[1.6] text-body sm:text-lg">
          요청서 한 번 남기면, 별도 연락 없이 가입설계 제안서가 도착해요.<br class="hidden sm:block" />
          어떤 상황에 얼마 받을 수 있는지, AI가 정리해드립니다.
        </p>

        <div class="mt-10 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-center">
          <a
            href={KAKAO_CHANNEL_CUSTOMER}
            class="inline-flex h-12 items-center justify-center rounded-md bg-brand px-6 text-[15px] font-medium text-white transition hover:bg-brand-active focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            일반고객으로 사전예약 →
          </a>
          <a
            href={KAKAO_CHANNEL_AGENT}
            class="inline-flex h-12 items-center justify-center rounded-md border border-hairline-strong bg-white px-6 text-[15px] font-medium text-ink transition hover:bg-canvas-soft focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
          >
            설계사로 사전예약 →
          </a>
        </div>

        <p class="mt-6 text-center text-[13px] text-muted">
          카카오톡 채널 추가로 사전예약 완료 · 약 1분 소요
        </p>
      </div>
    </section>

    <!-- Problem -->
    <section class="border-t border-hairline px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-section">
        <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="text-[11px] font-semibold uppercase tracking-caption text-muted">
              01 — Problem
            </span>
            <h2 class="mt-3 max-w-2xl font-normal leading-[1.15] tracking-display-snug text-ink text-[28px] sm:text-[40px]">
              보험 가입할 때,<br class="sm:hidden" /> 이런 경험 있으셨죠?
            </h2>
          </div>
          <p class="hidden max-w-sm text-[14px] leading-relaxed text-body sm:block">
            보험은 평생 한 번이 아닌, 평생 함께해야 하는 결정.<br />
            그 과정이 왜 이렇게 피곤해야 할까요.
          </p>
        </div>

        <ul class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {problems.map((item, idx) => (
            <li class="flex flex-col overflow-hidden rounded-card border border-hairline bg-white">
              <div class="aspect-[5/3] bg-canvas">
                <img
                  src={`/card-1-${idx + 1}.png`}
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover object-center"
                />
              </div>
              <div class="flex flex-col gap-5 p-8">
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[13px] text-muted">
                    0{idx + 1}
                  </span>
                </div>
                <h3 class="text-[19px] font-semibold leading-[1.35] text-ink sm:text-[20px]">
                  {item.title}
                </h3>
                <p class="text-[15px] leading-[1.65] text-body">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- How it works -->
    <section class="border-t border-hairline px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-section">
        <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="text-[11px] font-semibold uppercase tracking-caption text-muted">
              02 — How it works
            </span>
            <h2 class="mt-3 max-w-2xl font-normal leading-[1.15] tracking-display-snug text-ink text-[28px] sm:text-[40px]">
              요청 한 번이면,<br class="sm:hidden" /> 선택만 남습니다
            </h2>
          </div>
          <p class="hidden max-w-sm text-[14px] leading-relaxed text-body sm:block">
            가입자는 설계사를 찾지 않습니다.<br />
            설계사가 먼저 제안하고, AI가 비교합니다.
          </p>
        </div>

        <ol class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {steps.map((item, idx) => (
            <li class="flex flex-col overflow-hidden rounded-card border border-hairline bg-white">
              <div class="aspect-[5/3] bg-canvas">
                <img
                  src={`/card-2-${idx + 1}.png`}
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover object-center"
                />
              </div>
              <div class="flex flex-col gap-5 p-8">
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[13px] text-muted">
                    0{idx + 1}
                  </span>
                  <span class="text-[10px] font-semibold uppercase tracking-caption text-muted">
                    {item.label}
                  </span>
                </div>
                <h3 class="text-[19px] font-semibold leading-[1.35] text-ink sm:text-[20px]">
                  {item.title}
                </h3>
                <p class="text-[15px] leading-[1.65] text-body">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Solution -->
    <section class="border-t border-hairline px-6 py-20 sm:py-28">
      <div class="mx-auto max-w-section">
        <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="text-[11px] font-semibold uppercase tracking-caption text-muted">
              03 — Solution
            </span>
            <h2 class="mt-3 max-w-2xl font-normal leading-[1.15] tracking-display-snug text-ink text-[28px] sm:text-[40px]">
              세 가지 불편을, AI 한 번에 해결합니다
            </h2>
          </div>
          <p class="hidden max-w-sm text-[14px] leading-relaxed text-body sm:block">
            앞서 짚은 세 가지 불편을<br />
            Problem 1:1 매칭으로 해결합니다.
          </p>
        </div>

        <ul class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {solutions.map((item, idx) => (
            <li class="flex flex-col overflow-hidden rounded-card border border-hairline bg-white">
              <div class="aspect-[5/3] bg-canvas">
                <img
                  src={`/card-3-${idx + 1}.png`}
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover object-center"
                />
              </div>
              <div class="flex flex-col gap-5 p-8">
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[13px] text-muted">
                    0{idx + 1}
                  </span>
                  <span class="text-[10px] font-semibold uppercase tracking-caption text-muted">
                    ↳ Problem 0{idx + 1}
                  </span>
                </div>
                <h3 class="text-[19px] font-semibold leading-[1.35] text-ink sm:text-[20px]">
                  {item.title}
                </h3>
                <p class="text-[15px] leading-[1.65] text-body">
                  {item.description}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="border-t border-hairline px-6 py-24 sm:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <span class="text-[11px] font-semibold uppercase tracking-caption text-muted">
          사전예약
        </span>
        <h2 class="mt-4 font-normal leading-[1.12] tracking-display-tight text-ink text-[32px] sm:text-[52px]">
          지금 사전예약하고<br />
          오픈 소식<br class="sm:hidden" /> 가장 먼저 받아보세요
        </h2>
        <p class="mx-auto mt-6 max-w-lg text-[15px] leading-[1.65] text-body sm:text-base">
          Claim 카카오톡 채널을 추가하시면,<br class="sm:hidden" />
          서비스 오픈 시 가장 먼저 알려드립니다.
        </p>

        <div class="mt-10 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-center">
          <a
            href={KAKAO_CHANNEL_CUSTOMER}
            class="inline-flex h-12 items-center justify-center rounded-md bg-brand px-6 text-[15px] font-medium text-white transition hover:bg-brand-active focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          >
            일반고객으로 사전예약 →
          </a>
          <a
            href={KAKAO_CHANNEL_AGENT}
            class="inline-flex h-12 items-center justify-center rounded-md border border-hairline-strong bg-white px-6 text-[15px] font-medium text-ink transition hover:bg-canvas-soft focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
          >
            설계사로 사전예약 →
          </a>
        </div>

        <div class="mx-auto mt-12 flex max-w-md flex-col items-center gap-3 border-t border-hairline pt-8 text-[13px] text-muted sm:flex-row sm:justify-center sm:gap-6">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
            영업 전화 없음
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
            AI 약관 분석
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand"></span>
            제안서 자동 비교
          </span>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-hairline px-6 py-10">
    <div class="mx-auto flex max-w-section flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <img
        src="/claim_w_bg.png"
        alt="Claim"
        width="72"
        height="24"
        class="h-6 w-auto mix-blend-multiply"
      />
      <p class="text-[12px] text-muted">
        © {new Date().getFullYear()} Insupire Co., Ltd. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
