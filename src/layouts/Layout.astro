---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Claim — AI로 보험 상품을 분석하고 설계사를 비교해드립니다',
  description = '복잡한 약관, 끝없는 영업 전화. 보험 가입할 때 겪는 모든 피로를 AI가 대신 해결합니다. Claim 사전예약 신청하세요.',
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF8" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    <!-- Google tag (gtag.js) — Google Ads: AW-18152072488 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18152072488"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18152072488');
    </script>

    <!-- Event snippet for 리드 양식 제출 conversion page
    In your html page, add the snippet and call gtag_report_conversion when someone clicks on the chosen link or button. -->
    <script is:inline>
    function gtag_report_conversion(url) {
      var callback = function () {
        if (typeof(url) != 'undefined') {
          window.location = url;
        }
      };
      gtag('event', 'conversion', {
          'send_to': 'AW-18152072488/96KaCJmQq6ocEKjKys9D',
          'value': 1.0,
          'currency': 'KRW',
          'event_callback': callback
      });
      return false;
    }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-canvas font-sans text-ink antialiased [word-break:keep-all] selection:bg-brand/20 selection:text-ink">
    <slot />
  </body>
</html>
