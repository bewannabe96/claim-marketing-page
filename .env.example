# ─────────────────────────────────────────────────────────────
# Public client-side environment variables (PUBLIC_ prefix is required by Astro)
# Copy this file to `.env` for local development, and set the same keys in
# the Vercel project dashboard for deployments.
# ─────────────────────────────────────────────────────────────

# Customer pre-registration — Kakao channel "add friend" URL.
# Currently the 돕다 channel until the dedicated Claim channel is approved.
# Format: https://pf.kakao.com/_<CHANNEL_KEY>?utm_source=landing&utm_medium=cta&utm_campaign=customer
PUBLIC_KAKAO_CHANNEL_CUSTOMER=

# Insurance agent pre-registration — Google Form URL.
# Format: https://docs.google.com/forms/d/e/<FORM_ID>/viewform
PUBLIC_AGENT_FORM_URL=
